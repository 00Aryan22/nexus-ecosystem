# =============================================================================
# NEXUS AI — Environment Variables (SAFE TEMPLATE — no real secrets)
# Copy to .env.local at repo root and fill in values. Never commit .env.local
# =============================================================================

# --- Application ---
APP_ENV=development
APP_NAME=NEXUS AI

# --- Database ---
# For local Docker: postgresql+asyncpg://nexus:nexus@localhost:5432/nexus
# For Supabase hosted: postgresql+asyncpg://postgres:[PASSWORD]@[HOST].supabase.co:5432/postgres
DATABASE_URL=

# --- Redis ---
# Uses InMemoryRedis fallback if Redis is unreachable
REDIS_URL=redis://localhost:6379/0

# --- JWT (generate: python -c "import secrets; print(secrets.token_urlsafe(32))") ---
# REQUIRED: must be at least 32 characters long
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,https://nexus-ecosystem-web.vercel.app

# --- SIWE ---
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000
SIWE_CHAIN_ID=80002
SIWE_NONCE_TTL_SECONDS=300

# --- Next.js server (BFF proxy → FastAPI, not exposed to browser) ---
INTERNAL_API_URL=http://localhost:8000/api/v1

# --- Frontend (NEXT_PUBLIC_* = safe for browser exposure) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CHAIN_ID=80002
# REQUIRED: Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_APP_NAME=NEXUS AI
# Enable all frontend features (set to 'true' or '1')
NEXT_PUBLIC_FF_ALL=false
# Frontend-only RPC (optional, falls back to public RPC)
NEXT_PUBLIC_POLYGON_AMOY_RPC_URL=
NEXT_PUBLIC_ALCHEMY_POLYGON_AMOY_RPC_URL=
# Supabase public keys (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# When set to "true", frontend falls back to mock data for demos
NEXT_PUBLIC_USE_MOCKS=false

# --- AI (server-side only, never NEXT_PUBLIC_) ---
GEMINI_API_KEY=
EMERGENT_API_KEY=
EMERGENT_ENDPOINT=https://api.emergent.ai/v1/chat/completions
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SECONDS=0.5

# --- Google Stitch MCP ---
STITCH_URL=https://stitch.googleapis.com/mcp
STITCH_API_KEY=
STITCH_HEADER_NAME=X-Goog-Api-Key

# --- Blockchain (server-side only) ---
POLYGON_AMOY_RPC_URL=
DEPLOYER_PRIVATE_KEY=
RELAYER_PRIVATE_KEY=
SKILL_PASSPORT_CONTRACT_ADDRESS=
ALCHEMY_API_KEY=
ALCHEMY_POLYGON_AMOY_RPC_URL=

# --- IPFS / Pinata (server-side only) ---
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# --- Supabase server-side (back office, never commit) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Deployment ---
VERCEL_OIDC_TOKEN=
