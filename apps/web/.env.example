# Frontend-only variables (safe for browser exposure)
# Copy to apps/web/.env.local — never commit .env.local

INTERNAL_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_APP_NAME=NEXUS AI
# Optional: public RPC endpoints for frontend-only calls (read-only)
NEXT_PUBLIC_ALCHEMY_POLYGON_AMOY_RPC_URL=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# When set to "true", the frontend will fall back to local mock data for demos.
# Default: false (use real API via the Next.js proxy to the backend)
NEXT_PUBLIC_USE_MOCKS=false
