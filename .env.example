# =============================================================================
# NEXUS AI — Environment Variables (SAFE TEMPLATE — no real secrets)
# Copy to .env.local at repo root and fill in values. Never commit .env.local
# =============================================================================

# --- Application ---
APP_ENV=development
APP_NAME=NEXUS AI

# --- Database (Docker Compose defaults) ---
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (generate: python -c "import secrets; print(secrets.token_urlsafe(32))") ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# --- SIWE ---
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:3000
SIWE_CHAIN_ID=80002

# --- Next.js server (BFF → FastAPI, not exposed to browser) ---
INTERNAL_API_URL=http://localhost:8000/api/v1

# --- Frontend (NEXT_PUBLIC_* = safe for browser exposure) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CHAIN_ID=80002
# REQUIRED: Get from https://cloud.walletconnect.com (must be set for build)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_APP_NAME=NEXUS AI
# Enable all frontend features (set to 'true' or '1')
NEXT_PUBLIC_FF_ALL=false

# --- AI (Phase 5 — server-side only, never NEXT_PUBLIC_) ---
EMERGENT_API_KEY=
EMERGENT_ENDPOINT=https://api.emergent.ai/v1/chat/completions
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
STITCH_URL=https://stitch.googleapis.com/mcp
STITCH_API_KEY=
STITCH_HEADER_NAME=X-Goog-Api-Key
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Blockchain (Phase 6 — server-side only) ---
POLYGON_AMOY_RPC_URL=
DEPLOYER_PRIVATE_KEY=
RELAYER_PRIVATE_KEY=
SKILL_PASSPORT_CONTRACT_ADDRESS=
AUDIT_REGISTRY_CONTRACT_ADDRESS=
ALCHEMY_API_KEY=
ALCHEMY_POLYGON_AMOY_RPC_URL=

# --- IPFS / Pinata (Phase 6 — server-side only) ---
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# --- Supabase (optional) ---
# Public (frontend-safe) values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only service role key (never commit)
SUPABASE_SERVICE_ROLE_KEY=

# If using Supabase hosted Postgres direct connection (example):
# SUPABASE_DB_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.oinwkcxefniumshicvuj.supabase.co:5432/postgres

# --- Deployment (Phase 10) ---
VERCEL_TOKEN=
GITHUB_TOKEN=
BACKEND_HOST_URL=
